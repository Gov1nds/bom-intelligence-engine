# Core
PLATFORM_ENV=development
LOG_LEVEL=INFO
ENGINE_PORT=8001

# Auth (REQUIRED in production)
INTERNAL_API_KEY=

# File handling
BOM_ENGINE_UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_BYTES=52428800
ALLOWED_FILE_EXTENSIONS=.csv,.tsv,.xlsx,.xls,.txt

# Processing
ANALYSIS_TIMEOUT_SECONDS=120
NORMALIZATION_TIMEOUT_MS=500
ENRICHMENT_TIMEOUT_MS=1000
SCORING_TIMEOUT_MS=500
MAX_BOM_ROWS=5000

# Confidence thresholds (per SM-001)
CONFIDENCE_AUTO_THRESHOLD=0.85
CONFIDENCE_REVIEW_REQUIRED_THRESHOLD=0.50

# NLP / Model
NLP_MODEL_PATH=
PART_MASTER_INDEX_PATH=
ABBREVIATION_DICT_PATH=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=bom-intelligence-engine

# CORS
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
